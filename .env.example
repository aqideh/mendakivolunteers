# Public application configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-local-publishable-key

# Application environment. Production deployments must set this explicitly.
APP_ENV=development
AUTH_ALLOW_SIGN_UP=true

# Development and staging use the replaceable mock adapter.
YMHUB_CONNECTOR_MODE=mock

# Required only when YMHUB_CONNECTOR_MODE=salesforce.
YMHUB_BASE_URL=
YMHUB_CLIENT_ID=
YMHUB_CLIENT_SECRET=

# Volunteer identity mapping.
YMHUB_VOLUNTEER_OBJECT_API=[YMH_VOLUNTEER_OBJECT_API]
YMHUB_VOLUNTEER_ID_FIELD_API=[YMH_VOLUNTEER_ID_API]
YMHUB_VOLUNTEER_STATUS_FIELD_API=[YMH_VOLUNTEER_STATUS_API]
YMHUB_VOLUNTEER_UPDATED_AT_FIELD_API=[YMH_VOLUNTEER_UPDATED_AT_API]

# Registration read-model mapping.
YMHUB_REGISTRATION_OBJECT_API=[YMH_REGISTRATION_OBJECT_API]
YMHUB_REGISTRATION_ID_FIELD_API=[YMH_REGISTRATION_ID_API]
YMHUB_REGISTRATION_VOLUNTEER_FIELD_API=[YMH_REGISTRATION_VOLUNTEER_API]
YMHUB_REGISTRATION_ACTIVITY_FIELD_API=[YMH_REGISTRATION_ACTIVITY_API]
YMHUB_REGISTRATION_STATUS_FIELD_API=[YMH_REGISTRATION_STATUS_API]
YMHUB_REGISTRATION_REGISTERED_AT_FIELD_API=[YMH_REGISTRATION_REGISTERED_AT_API]
YMHUB_REGISTRATION_UPDATED_AT_FIELD_API=[YMH_REGISTRATION_UPDATED_AT_API]

# Attendance read-model mapping.
YMHUB_ATTENDANCE_OBJECT_API=[YMH_ATTENDANCE_OBJECT_API]
YMHUB_ATTENDANCE_ID_FIELD_API=[YMH_ATTENDANCE_ID_API]
YMHUB_ATTENDANCE_VOLUNTEER_FIELD_API=[YMH_ATTENDANCE_VOLUNTEER_API]
YMHUB_ATTENDANCE_ACTIVITY_FIELD_API=[YMH_ATTENDANCE_ACTIVITY_API]
YMHUB_ATTENDANCE_STATUS_FIELD_API=[YMH_ATTENDANCE_STATUS_API]
YMHUB_ATTENDANCE_HOURS_FIELD_API=[YMH_ATTENDANCE_HOURS_API]
YMHUB_ATTENDANCE_VERIFIED_AT_FIELD_API=[YMH_ATTENDANCE_VERIFIED_AT_API]
YMHUB_ATTENDANCE_UPDATED_AT_FIELD_API=[YMH_ATTENDANCE_UPDATED_AT_API]

# Related activity fields used by both projections.
YMHUB_ACTIVITY_ID_FIELD_API=[YMH_ACTIVITY_ID_API]
YMHUB_ACTIVITY_TITLE_FIELD_API=[YMH_ACTIVITY_TITLE_API]
YMHUB_ACTIVITY_CATEGORY_FIELD_API=[YMH_ACTIVITY_CATEGORY_API]
YMHUB_ACTIVITY_START_AT_FIELD_API=[YMH_ACTIVITY_START_AT_API]
YMHUB_ACTIVITY_END_AT_FIELD_API=[YMH_ACTIVITY_END_AT_API]
