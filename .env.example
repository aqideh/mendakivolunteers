# Public application configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-local-publishable-key

# Application environment. Production deployments must set this explicitly.
APP_ENV=development
AUTH_ALLOW_SIGN_UP=true

# Phase 1 uses the replaceable mock adapter.
YMHUB_CONNECTOR_MODE=mock

# Required only when YMHUB_CONNECTOR_MODE=salesforce.
YMHUB_BASE_URL=
YMHUB_CLIENT_ID=
YMHUB_CLIENT_SECRET=
YMHUB_VOLUNTEER_OBJECT_API=[YMH_VOLUNTEER_OBJECT_API]
YMHUB_VOLUNTEER_ID_FIELD_API=[YMH_VOLUNTEER_ID_API]
YMHUB_VOLUNTEER_STATUS_FIELD_API=[YMH_VOLUNTEER_STATUS_API]
YMHUB_VOLUNTEER_UPDATED_AT_FIELD_API=[YMH_VOLUNTEER_UPDATED_AT_API]
