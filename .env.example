# Public application configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-local-publishable-key

# Application environment. Production deployments must set this explicitly.
APP_ENV=development
AUTH_ALLOW_SIGN_UP=true

# Comma-separated DNS hostnames accepted for external registration links.
YMHUB_REGISTRATION_ALLOWED_HOSTS=example.invalid
